# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#
# ── INSFORGE ───────────────────────────────────────────────────
NEXT_PUBLIC_INSFORGE_BASE_URL=https://YOUR_APPKEY.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key-here
# Optional: server-only base URL override (same as public URL if left empty)
INSFORGE_BASE_URL=
# Server only — elevated/server secret from Insforge when needed (never expose to client)
INSFORGE_SERVER_SECRET=
# Server only — webhook signing secret for POST /api/webhooks/insforge
INSFORGE_WEBHOOK_SECRET=

# ── APP (auth URLs — optional; code defaults redirects to /dashboard) ──
NEXT_PUBLIC_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_AFTER_SIGN_UP_URL=/dashboard

# ── ANTHROPIC (AI Agents) ───────────────────────────────────────
# Server only — never expose
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── EMAIL (Resend) ───────────────────────────────────────────────
# Server only
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=noreply@worshipbuilderscollective.org

# ── APP ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WBC Hub
